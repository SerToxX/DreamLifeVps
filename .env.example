# ─────────────────────────────────────────────
# Copia esto como .env y reemplaza los valores.
# Genera contraseñas con: openssl rand -base64 24
# Genera secretos JWT con: openssl rand -hex 64
# NUNCA subas el .env real a git (ya está en .gitignore).
# ─────────────────────────────────────────────

NODE_ENV=production
PORT=3001
FRONTEND_URL=https://tudominio.com

# ── Base de datos (MySQL) ──
DB_ROOT_PASSWORD=cambia_esto
DB_NAME=dream_life
DB_USER=dreamlife
DB_PASSWORD=cambia_esto
# OJO: DATABASE_URL no interpola DB_PASSWORD automáticamente,
# copia aquí el MISMO valor que pusiste en DB_PASSWORD
DATABASE_URL=mysql://dreamlife:cambia_esto@mysql:3306/dream_life

# ── JWT ──
JWT_SECRET=cambia_esto_64_caracteres_minimo
JWT_REFRESH_SECRET=otro_secreto_diferente_64_caracteres
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── Rate limiting ──
THROTTLE_TTL=60000
THROTTLE_LIMIT=100

# ── Uploads ──
UPLOAD_PATH=./uploads
MAX_FILE_SIZE=5242880

# ── Frontend (Next.js) — se hornean en el build, no solo runtime ──
NEXT_PUBLIC_API_URL=https://api.tudominio.com/api/v1
NEXT_PUBLIC_SOCKET_URL=https://api.tudominio.com
NEXT_PUBLIC_APP_NAME=Dream Life
