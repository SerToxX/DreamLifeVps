# Para desarrollo local SIN Docker cambia a:
# DATABASE_URL="mysql://root:tu_password@localhost:3306/dream_life"

# ─────────────────────────────────────────────
# JWT
# ─────────────────────────────────────────────
JWT_SECRET=cambia_esto_por_una_clave_secreta_muy_larga_64_caracteres_minimo
JWT_REFRESH_SECRET=otra_clave_secreta_para_refresh_token_diferente_a_la_anterior
