# ─────────────────────────────────────────────
# APP
# ─────────────────────────────────────────────
PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# ─────────────────────────────────────────────
# RATE LIMITING
# ─────────────────────────────────────────────
THROTTLE_TTL=60000
THROTTLE_LIMIT=100

# ─────────────────────────────────────────────
# UPLOADS
# ─────────────────────────────────────────────
UPLOAD_PATH=./uploads
MAX_FILE_SIZE=5242880
